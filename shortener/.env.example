# Shortener Service Configuration

# Database
DATABASE_URL=postgres://shortener:shortener@localhost:5433/shortener?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# Ports
GRPC_PORT=9091
HTTP_PORT=8082

# FileUpload gRPC address
FILEUPLOAD_GRPC_ADDR=localhost:9090

# Base URL for short links (public facing)
BASE_URL=http://localhost:8082

# Logging
LOG_LEVEL=info
