# Auth Service Configuration
# Copy this file to .env and fill in your values.

DATABASE_URL=postgres://gobox:gobox@localhost:5432/gobox_auth?sslmode=disable
GRPC_PORT=8081
HTTP_PORT=8080

# Path to the RSA private key PEM file (required).
# Generate with: openssl genrsa -out private.pem 2048
JWT_PRIVATE_KEY_PATH=./private.pem

# Path to the previous RSA private key PEM file (optional, for key rotation overlap).
JWT_PREVIOUS_PRIVATE_KEY_PATH=

LOG_LEVEL=debug
