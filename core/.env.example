# Core API Configuration
# Native-development values. Docker Compose overrides these with container
# hostnames (e.g., auth:8081) — see core/docker-compose.yml.

HTTP_PORT=8080
AUTH_GRPC_ADDR=localhost:8081
AUTH_HTTP_ADDR=http://localhost:8080
FILEUPLOAD_GRPC_ADDR=localhost:9090
# Shortener gRPC address. Leave empty to disable short link functionality.
SHORTENER_GRPC_ADDR=localhost:9091
# ThumbGen gRPC address. Leave empty to disable thumbnail generation (nil-guarded stub).
THUMBGEN_GRPC_ADDR=localhost:9092

LOG_LEVEL=info
# JWKS_REFRESH_INTERVAL=5m

# LOG_FORMAT=pretty   # uncomment for human-readable output during local dev
