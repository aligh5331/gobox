# FileUpload Service Configuration

# Database
DATABASE_URL=postgres://fileupload:fileupload@localhost:5435/fileupload?sslmode=disable

# gRPC Port
GRPC_PORT=9090

# S3/MinIO Configuration
S3_ENDPOINT=localhost:9000
S3_BUCKET=uploads
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# Optional: Override endpoint used in presigned URLs (for in-cluster vs public access)
# S3_PUBLIC_ENDPOINT=

# Presigned URL TTLs (minutes)
PRESIGN_UPLOAD_TTL_MINUTES=15
PRESIGN_DOWNLOAD_TTL_MINUTES=60

# Max file size (bytes, default 100 MiB = 104857600)
MAX_FILE_SIZE=104857600
